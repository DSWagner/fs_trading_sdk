{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm install && cd demo-app && npm run build",
  "outputDirectory": "demo-app/dist",
  "framework": null,
  "installCommand": "echo skipping root install (build script installs workspace)",
  "env": {
    "VITE_FS_BASE_URL": "https://fs-engine-api-dev.onrender.com"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "interest-cohort=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon|og-card)\\.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
